# ── watsonx Orchestrate ─────────────────────────────────────────────────────
WXO_INSTANCE_URL=https://api.us-south.watson-orchestrate.cloud.ibm.com/instances/<your-instance-id>
WXO_API_KEY=<your-wxo-api-key>
WXO_MODEL=watsonx/ibm/granite-3-8b-instruct

# ── PostgreSQL (matches docker-compose.yml defaults) ────────────────────────
POSTGRES_USER=commai
POSTGRES_PASSWORD=commai_secret
POSTGRES_DB=commai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql://commai:commai_secret@localhost:5432/commai

# ── Backend ──────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# ── MCP ──────────────────────────────────────────────────────────────────────
WXO_MCP_URL=https://developer.watson-orchestrate.ibm.com/mcp
